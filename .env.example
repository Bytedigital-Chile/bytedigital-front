# ByteDigital Front - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# API Configuration
# =============================================================================

# API URL for server-side rendering (SSR)
# Used when Nuxt server fetches data during SSR
# In Docker, this should point to the internal service name (e.g., http://api:8000)
NUXT_API_BASE=http://localhost:8000

# API URL for client-side (browser)
# Used when JavaScript in the browser makes API calls
# Should be the public URL that browsers can reach
NUXT_PUBLIC_API_BASE=http://localhost:8000

# =============================================================================
# Google OAuth (Optional)
# =============================================================================

# Google OAuth 2.0 Client ID for Sign-In
# Create at: https://console.cloud.google.com/apis/credentials
# Leave empty to disable Google Sign-In
NUXT_PUBLIC_GOOGLE_CLIENT_ID=

# =============================================================================
# Build Configuration
# =============================================================================

# Nitro preset for deployment
# Options: node-server (default), vercel, netlify, cloudflare, etc.
# See: https://nitro.unjs.io/deploy
NITRO_PRESET=node-server
